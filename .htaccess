# Promoters本番サーバー(さくらインターネット)用セキュリティ設定
# GitHub Pagesではこのファイルは無視される（プレビュー環境には影響なし）

# ディレクトリ一覧の閲覧禁止
Options -Indexes

# 隠しファイル・バックアップファイル・設定ファイルへのアクセス禁止
<FilesMatch "(^\.|\.(bak|old|orig|save|swp|log|sql|zip)$)">
  Require all denied
</FilesMatch>

# クリックジャッキング・MIMEスニッフィング・リファラー漏洩対策
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' mailto:; frame-ancestors 'self'"
</IfModule>

